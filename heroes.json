            border: 2px solid var(--hex-gold-dark);
            color: var(--hex-gold-light);
            transition: all 0.3s ease;
        }

        .search-input:focus {
            border-color: var(--hex-gold-main);
            box-shadow: 0 0 15px rgba(200, 155, 60, 0.2);
            outline: none;
        }

        .tier-S { color: #ff4e50; text-shadow: 0 0 8px rgba(255, 78, 80, 0.4); font-weight: bold; }
        .tier-A { color: #f9d423; text-shadow: 0 0 8px rgba(249, 212, 35, 0.4); font-weight: bold; }
        
        .tag-chip {
            background: linear-gradient(90deg, rgba(200,155,60,0.15) 0%, rgba(200,155,60,0.05) 100%);
            border: 1px solid var(--hex-border);
            color: var(--hex-gold-main);
            font-size: 0.75rem;
            padding: 0.25rem 0.75rem;
        }

        .item-chip {
            background: rgba(3, 151, 171, 0.15);
            border: 1px solid rgba(3, 151, 171, 0.4);
            color: #a0e8f5;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--hex-bg-deep); }
        ::-webkit-scrollbar-thumb { background: var(--hex-gold-dark); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--hex-gold-main); }
    </style>
</head>
<body class="p-4 sm:p-8">

<div class="max-w-4xl mx-auto">
    <div class="text-center mb-10 mt-4">
        <div class="inline-block px-4 py-1 border border-[#c89b3c]/30 text-[#0397ab] text-xs tracking-widest uppercase mb-4 bg-[#0a1428]/50">
            Wild Rift Patch <span id="patchVersion">7.2a</span> Complete Edition
        </div>
        <h1 class="text-4xl md:text-5xl font-black lol-title mb-3">上单 BP 战术助手</h1>
        <p class="text-[#785a28] text-sm tracking-wider">先选己方英雄，再输入敌方上单，获得 7.2a 情景化鞋子与反制装备</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-10 z-10 relative">
        <select id="ownChampionSelect" class="search-input py-4 px-4 text-base font-medium" disabled>
            <option value="">选择我方上单（推荐）</option>
        </select>
        <div class="relative md:col-span-2">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-[#c89b3c]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </div>
            <input type="text" id="searchInput" 
                class="w-full search-input py-4 pl-12 pr-4 text-lg font-medium placeholder-[#785a28]"
                placeholder="正在加载数据库..." 
                autocomplete="off"
                disabled>
        </div>
    </div>

    <div id="suggestions" class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8 hidden"></div>

    <div id="resultPanel" class="lol-card p-6 md:p-8 hidden">
        <div class="border-b border-[#c89b3c]/30 pb-4 mb-6 flex items-center justify-between">
            <div>
                <h2 id="enemyName" class="text-3xl font-bold lol-title text-white"></h2>
                <div id="enemyTags" class="flex flex-wrap gap-2 mt-3"></div>
            </div>
            <div class="text-right hidden sm:block">
                <div class="text-[#785a28] text-xs uppercase tracking-widest">Target Acquired</div>
                <div class="text-[#c89b3c] font-bold mt-1">敌方档案已确认</div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="space-y-6 md:col-span-1">
                <div>
                    <h3 class="text-[#0397ab] font-bold text-lg mb-3 uppercase flex items-center gap-2">
                        <span class="w-2 h-2 bg-[#0397ab] rotate-45 inline-block"></span> 推荐选角 (Counter)
                    </h3>
                    <div class="bg-[#010a13]/60 p-4 border border-[#0a1428]">
                        <div class="mb-4">
                            <span class="tier-S text-sm block mb-2">S级 (极度克制)</span>
                            <div id="counterS" class="flex flex-wrap gap-2"></div>
                        </div>
                        <div>
                            <span class="tier-A text-sm block mb-2">A级 (优势对线)</span>
                            <div id="counterA" class="flex flex-wrap gap-2"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="md:col-span-2 space-y-6">
                <div>
                    <h3 class="text-[#c89b3c] font-bold text-lg mb-3 uppercase flex items-center gap-2">
                        <span class="w-2 h-2 bg-[#c89b3c] rotate-45 inline-block"></span> 核心针对装备 (Anti-Build)
                    </h3>
                    <div class="bg-[#010a13]/60 p-4 border border-[#0a1428]">
                        <div class="text-[#785a28] text-sm mb-4">基于敌方英雄属性标签，强烈建议优先考虑以下针对装备：</div>
                        <div id="antiItems" class="flex flex-wrap gap-3"></div>
                    </div>
                </div>

                <div>
                    <h3 class="text-[#0397ab] font-bold text-lg mb-3 uppercase flex items-center gap-2">
                        <span class="w-2 h-2 bg-[#0397ab] rotate-45 inline-block"></span> 7.2a 鞋子路线
                    </h3>
                    <div class="bg-[#010a13]/60 p-4 border border-[#0a1428]">
                        <div id="bootRoute" class="space-y-2"></div>
                        <div class="text-[#785a28] text-xs mt-3">三级鞋统一在 10:00 后开放。鞋子不再附魔；金身、推推棒、水银、石像鬼等现为按职业限制的完整主动装备。</div>
                    </div>
                </div>

                <div>
                    <h3 class="text-[#c89b3c] font-bold text-lg mb-3 uppercase flex items-center gap-2">
                        <span class="w-2 h-2 bg-[#c89b3c] rotate-45 inline-block"></span> 主动装备建议
                    </h3>
                    <div class="bg-[#010a13]/60 p-4 border border-[#0a1428]">
                        <div id="activeRecommendation" class="space-y-2 text-sm"></div>
                    </div>
                </div>

                <div>
                    <h3 class="text-[#f0e6d2] font-bold text-lg mb-3 uppercase flex items-center gap-2">
                        <span class="w-2 h-2 bg-[#f0e6d2] rotate-45 inline-block"></span> 对线核心口诀
                    </h3>
                    <div class="bg-[#010a13]/60 p-5 border border-[#0a1428]">
                        <ul id="tipsList" class="space-y-3 text-sm leading-relaxed text-[#c8aa6e] list-disc pl-4"></ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="emptyState" class="text-center py-16 opacity-50">
        <svg class="w-16 h-16 mx-auto text-[#785a28] mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
        <p id="emptyStateText" class="text-[#785a28] text-lg font-serif">正在初始化数据库连接...</p>
    </div>

    <details class="lol-card mt-8 p-5" id="equipmentLibrary">
        <summary class="cursor-pointer text-[#c89b3c] font-bold text-lg">7.2a 装备速查库（完整鞋线与主动装备）</summary>
        <div class="mt-5">
            <h3 class="text-[#0397ab] font-bold mb-3">7 条鞋子升级路线</h3>
            <div id="allBoots" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
            <h3 class="text-[#0397ab] font-bold mt-7 mb-3">主动装备（原鞋子附魔体系）</h3>
            <div id="allActiveItems" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
            <h3 class="text-[#0397ab] font-bold mt-7 mb-3">7.2 新增法师装备</h3>
            <div id="allMageItems" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
        </div>
    </details>
</div>

<script>
    let itemIcons = {};
    let itemDictionary = {};
    let bpDatabase = {};
    let bootRoutes = {};
    let patchInfo = {};
    let ownChampionProfiles = {};
    let activeItemProfiles = {};
    let equipmentCatalog = {};
    let currentEnemy = null;

    const searchInput = document.getElementById('searchInput');
    const suggestionsPanel = document.getElementById('suggestions');
    const resultPanel = document.getElementById('resultPanel');
    const emptyState = document.getElementById('emptyState');
    const emptyStateText = document.getElementById('emptyStateText');
    const ownChampionSelect = document.getElementById('ownChampionSelect');

    async function initApp() {
        try {
            const response = await fetch('heroes.json');
            if (!response.ok) {
                throw new Error('网络请求失败');
            }
            const data = await response.json();
            
            // 加载包含新版图标信息的 JSON 数据
            itemIcons = data.itemIcons || {};
            itemDictionary = data.itemDictionary;
            bpDatabase = data.bpDatabase;
            bootRoutes = data.bootRoutes || {};
            patchInfo = data.patch || {};
            ownChampionProfiles = data.ownChampionProfiles || {};
            activeItemProfiles = data.activeItemProfiles || {};
            equipmentCatalog = data.equipmentCatalog || {};
            document.getElementById('patchVersion').textContent = patchInfo.version || '7.2a';
            
            const heroCount = Object.keys(bpDatabase).length;
            emptyStateText.textContent = `等待 BP 指令输入... (已载入 ${heroCount} 名上单数据)`;
            searchInput.placeholder = "对面选了什么？(例如：奥恩、腕豪、剑姬)...";
            searchInput.disabled = false;
            ownChampionSelect.innerHTML = '<option value="">选择我方上单（推荐）</option>' +
                Object.keys(bpDatabase).sort((a, b) => a.localeCompare(b, 'zh-CN'))
                    .map(name => `<option value="${name}">${name}</option>`).join('');
            ownChampionSelect.disabled = false;
            ownChampionSelect.addEventListener('change', () => {
                if (currentEnemy) renderHero(currentEnemy.name, currentEnemy.data);
            });
            renderEquipmentLibrary();
            
            searchInput.addEventListener('input', handleSearch);

        } catch (error) {
            console.error('加载英雄数据库失败:', error);
            emptyStateText.textContent = '数据库加载失败。请确保 index.html 和 heroes.json 在同一文件夹，并已部署至服务器环境。';
            searchInput.placeholder = "读取数据失败";
        }
    }

    // 生成出装对象 (附带图标链接)
    function generateAntiItems(tags) {
        let itemsMap = new Map();
        tags.forEach(tag => {
            if (itemDictionary[tag]) {
                itemDictionary[tag].forEach(itemName => {
                    if (!itemsMap.has(itemName)) {
                        itemsMap.set(itemName, itemIcons[itemName] || "");
                    }
                });
            }
        });
        
        return Array.from(itemsMap, ([name, iconUrl]) => ({ name, iconUrl })).slice(0, 5); 
    }

    function selectDefensiveBootRoute(tags) {
        if (tags.includes('魔法消耗') || tags.includes('AP坦克')) return bootRoutes.magic;
        if (tags.includes('平A依赖') || tags.includes('暴击怪') || tags.includes('物理爆发')) return bootRoutes.physical;
        return bootRoutes.sustain;
    }

    function renderBootCard(boot, label) {
        if (!boot) return '';
        return `<div class="border border-[#0397ab]/30 bg-[#0a1428]/50 p-3 rounded">
            <div class="text-xs text-[#785a28] mb-2">${label}</div>
            <div class="flex flex-wrap items-center gap-2 text-sm">
                <span class="px-2.5 py-1 border border-[#0397ab]/40 text-[#a0e8f5] rounded">${boot.level2}</span>
                <span class="text-[#785a28]">→ 10:00 →</span>
                <span class="px-2.5 py-1 border border-[#c89b3c]/50 text-[#f0e6d2] rounded">${boot.level3}</span>
            </div>
            <div class="text-[#c8aa6e] text-sm leading-relaxed mt-2">${boot.reason}</div>
            <div class="text-[#785a28] text-xs mt-1">${boot.timing}</div>
        </div>`;
    }

    function renderEquipmentLibrary() {
        document.getElementById('allBoots').innerHTML = (equipmentCatalog.boots || []).map(boot => `
            <div class="bg-[#010a13]/60 border border-[#0a1428] p-3 text-sm">
                <div class="text-[#f0e6d2] font-bold">${boot.level2} <span class="text-[#785a28]">→</span> ${boot.level3}</div>
                <div class="text-[#785a28] mt-1">${boot.role}</div>
            </div>`).join('');
        document.getElementById('allActiveItems').innerHTML = (equipmentCatalog.activeItems || []).map(item => `
            <div class="bg-[#010a13]/60 border border-[#0a1428] p-3 text-sm">
                <div class="text-[#f0e6d2] font-bold">${item.name}</div>
                <div class="text-[#0397ab] text-xs mt-1">${item.class}</div>
                <div class="text-[#c8aa6e] mt-1">${item.purpose}</div>
            </div>`).join('');
        document.getElementById('allMageItems').innerHTML = (equipmentCatalog.newMageItems || []).map(item => `
            <div class="bg-[#010a13]/60 border border-[#0a1428] p-3 text-sm">
                <div class="text-[#f0e6d2] font-bold">${item.name}</div>
                <div class="text-[#0397ab] text-xs mt-1">${item.type}</div>
                <div class="text-[#c8aa6e] mt-1">${item.purpose}</div>
            </div>`).join('');
    }

    function renderHero(name, data) {
        currentEnemy = { name, data };
        suggestionsPanel.classList.add('hidden');
        emptyState.classList.add('hidden');
        resultPanel.classList.remove('hidden');

        document.getElementById('enemyName').textContent = name;
        
        const tagsHtml = data.tags.map(tag => `<span class="tag-chip rounded-full">${tag}</span>`).join('');
        document.getElementById('enemyTags').innerHTML = tagsHtml;

        document.getElementById('counterS').innerHTML = data.counters.S.map(h => `<span class="px-3 py-1 bg-red-500/10 border border-red-500/30 text-red-300 rounded text-sm">${h}</span>`).join('');
        document.getElementById('counterA').innerHTML = data.counters.A.map(h => `<span class="px-3 py-1 bg-yellow-500/10 border border-yellow-500/30 text-yellow-300 rounded text-sm">${h}</span>`).join('');

        // 渲染带图标的出装面板
        const antiItemsData = generateAntiItems(data.tags);
        document.getElementById('antiItems').innerHTML = antiItemsData.map(item => `
            <div class="item-chip px-3 py-1.5 rounded-md text-sm font-medium tracking-wide">
                ${item.iconUrl ? `<img src="${item.iconUrl}" class="w-7 h-7 rounded border border-[#0397ab]/40 shadow-sm" alt="${item.name}" onerror="this.style.display='none'">` : ''}
                <span>${item.name}</span>
            </div>
        `).join('');

        const defensiveBoot = selectDefensiveBootRoute(data.tags);
        const ownName = ownChampionSelect.value;
        const ownProfile = ownChampionProfiles[ownName];
        const carryBoot = ownProfile ? bootRoutes[ownProfile.boot] : null;
        const isSameRoute = carryBoot && defensiveBoot && carryBoot.level3 === defensiveBoot.level3;
        document.getElementById('bootRoute').innerHTML =
            renderBootCard(defensiveBoot, '对线抗压首选') +
            (!isSameRoute && carryBoot ? renderBootCard(carryBoot, `${ownName} 发育/优势路线`) : '') +
            (!ownName ? '<div class="text-[#785a28] text-xs">选择己方英雄后，会同时显示英雄专属的输出/功能鞋路线。</div>' : '');

        const activeNames = ownProfile ? (activeItemProfiles[ownProfile.class] || []) : [];
        document.getElementById('activeRecommendation').innerHTML = ownProfile ?
            `<div class="text-[#785a28] mb-2">${ownName}（${ownProfile.class}）可购买：</div>` +
            activeNames.map(item => `<span class="inline-block mr-2 mb-2 px-3 py-1.5 rounded border border-[#c89b3c]/40 text-[#f0e6d2]">${item}</span>`).join('') +
            '<div class="text-[#785a28] text-xs mt-1">7.2 后主动装备按职业开放，商店内若显示不可购买，以游戏内职业判定为准。</div>' :
            '<div class="text-[#785a28]">选择己方英雄后显示可用主动装备。</div>';

        document.getElementById('tipsList').innerHTML = data.tips.map(tip => `<li>${tip}</li>`).join('');
    }

    function handleSearch() {
        const query = searchInput.value.trim().toLowerCase();
        
        if (!query) {
            suggestionsPanel.classList.add('hidden');
            resultPanel.classList.add('hidden');
            emptyState.classList.remove('hidden');
            return;
        }

        const matches = [];
        for (const [name, data] of Object.entries(bpDatabase)) {
            if (name.includes(query) || data.aliases.some(alias => alias.includes(query))) {
                matches.push({ name, data });
            }
        }

        if (matches.length === 1 && matches[0].name === query) {
            renderHero(matches[0].name, matches[0].data);
        } else if (matches.length > 0) {
            resultPanel.classList.add('hidden');
            emptyState.classList.add('hidden');
            suggestionsPanel.classList.remove('hidden');
            
            suggestionsPanel.innerHTML = matches.map(match => `
                <button onclick="selectHero('${match.name}')" class="lol-card p-3 text-left hover:bg-[#0397ab]/10 transition-colors group">
                    <div class="text-[#c89b3c] font-bold group-hover:text-[#f0e6d2]">${match.name}</div>
                    <div class="text-[#785a28] text-xs mt-1 truncate">${match.data.aliases.join(' / ')}</div>
                </button>
            `).join('');
        } else {
            suggestionsPanel.classList.add('hidden');
            resultPanel.classList.add('hidden');
            emptyState.classList.remove('hidden');
        }
    }

    window.selectHero = function(name) {
        searchInput.value = name;
        renderHero(name, bpDatabase[name]);
    };

    document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            searchInput.focus();
        }
    });

    initApp();

</script>
</body>
</html>

