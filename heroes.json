  "bpDatabase": {
    "德莱厄斯": {
      "aliases": ["诺手", "断头台"],
      "tags": ["回复怪", "真伤", "物理爆发"],
      "counters": {
        "S": ["杰斯", "提莫", "薇恩"],
        "A": ["赛恩", "蒙多", "内瑟斯"]
      },
      "tips": [
        "【核心】内圈 Q 不会回血且伤害低，如果被无情铁手拉过去，可以直接贴脸打。",
        "【拉扯】不要轻易交出关键位移，保持在他 E 技能范围边缘疯狂拉扯。",
        "【血怒】五层血怒后尽量避战，不要在残血时赌他的大招斩杀线。"
      ]
    },
    "盖伦": {
      "aliases": ["大宝剑", "草丛伦"],
      "tags": ["回复怪", "真伤", "物理爆发"],
      "counters": {
        "S": ["卡蜜尔", "薇恩", "德莱厄斯"],
        "A": ["格温", "纳尔"]
      },
      "tips": [
        "【减伤】守望者铠甲完美压制他的转圈圈伤害，神分/破败打高血量盖伦有奇效。",
        "【被动】利用平A或小技能打断他的脱战回血被动。",
        "【斩杀】注意自身血线，如果头上出现“大反派”标记或半血以下，不要硬拼。"
      ]
    },
    "瑟提": {
      "aliases": ["腕豪", "劲夫"],
      "tags": ["回复怪", "高生命", "真伤", "平A依赖"],
      "counters": {
        "S": ["雷克顿", "沃利贝尔", "杰斯"],
        "A": ["奥拉夫", "凯南", "格温"]
      },
      "tips": [
        "【站位】对拼时利用位移绕到他身后，绝对不要硬吃满蓄力 W 的中心真实伤害。",
        "【拉扯】破舰者+血铠的瑟提单挑极强，没有绝对把握不要站撸，打完一套就撤。",
        "【装备】面对他的巨额护盾，刺客或部分轻装战士可以考虑出【巨蛇之牙】。"
      ]
    },
    "莫德凯撒": {
      "aliases": ["铁男", "金属大师"],
      "tags": ["魔法消耗", "AP坦克", "高生命"],
      "counters": {
        "S": ["奥拉夫", "菲奥娜", "薇恩"],
        "A": ["贾克斯", "卡蜜尔"]
      },
      "tips": [
        "【水银鞋】首件必做水银之靴，不仅提供魔抗，还能减少控制时间。",
        "【拖延】7.2 后金身已从鞋子附魔拆出；仅法师可用探索者的护臂/中娅沙漏拖延大招时间，战士应靠走位、回复与抗性硬撑。",
        "【魔抗】优先做出败魔或自然之力，魔法护盾能完美抵消他的被动和Q。"
      ]
    },
    "亚托克斯": {
      "aliases": ["剑魔", "天神下凡"],
      "tags": ["回复怪", "物理爆发"],
      "counters": {
        "S": ["菲奥娜", "艾瑞莉娅", "克烈"],
        "A": ["赛恩", "盖伦", "蒙多"]
      },
      "tips": [
        "【必出】第一次回家无论如何必须做出死刑宣告或荆棘背心断其吸血。",
        "【规避】向内走位躲避 Q1 和 Q2 的外圈，Q3 时交位移拉开。",
        "【护甲】他的所有伤害均为纯物理伤害，裸出铁板靴性价比极高。"
      ]
    },
    "俄洛伊": {
      "aliases": ["触手妈", "海兽祭司"],
      "tags": ["回复怪", "物理爆发"],
      "counters": {
        "S": ["提莫", "莫德凯撒", "格温"],
        "A": ["薇恩", "杰斯"]
      },
      "tips": [
        "【重伤】面对她极强的阵地回复能力，首件必须掏出重伤散件。",
        "【躲避】走位或留位移躲避她的E（灵魂试炼），一旦被拉必须立刻反打或直接撤出范围。",
        "【大招】当她开启大招（过界信仰）砸地板时，绝对、千万、不要站撸，立刻跑！"
      ]
    },
    "沃利贝尔": {
      "aliases": ["狗熊", "不灭狂雷"],
      "tags": ["回复怪", "魔法消耗", "平A依赖"],
      "counters": {
        "S": ["提莫", "杰斯", "墨菲特"],
        "A": ["薇恩", "凯南"]
      },
      "tips": [
        "【减速】小反甲不仅断其W回血，冰心还能大幅减缓其攻速和被动闪电链触发频率。",
        "【标记】如果头上出现他W的印记，立刻后撤，不要让他咬出带有巨额回血的第二口。",
        "【越塔】小心他大招屏蔽防御塔的机制，残血在塔下并不安全。"
      ]
    },
    "厄加特": {
      "aliases": ["螃蟹", "战车"],
      "tags": ["物理爆发", "高生命"],
      "counters": {
        "S": ["奥拉夫", "慎", "薇恩"],
        "A": ["提莫", "杰斯"]
      },
      "tips": [
        "【克制】小反甲和守望者铠甲完美克制其W技能的高频低伤。",
        "【走位】对拼时贴身并保持在他同一方向，不要让他打出四周所有腿炮的被动爆发。",
        "【前摇】留好位移躲避他前摇明显的E技能（背摔）。"
      ]
    },
    "内瑟斯": {
      "aliases": ["狗头", "沙漠死神"],
      "tags": ["回复怪", "高生命", "物理爆发"],
      "counters": {
        "S": ["德莱厄斯", "奥拉夫", "提莫"],
        "A": ["杰斯", "薇恩"]
      },
      "tips": [
        "【压制】前三级是他最弱的时候，呼叫打野越塔或疯狂控线，绝对不要让他安稳叠Q。",
        "【韧性】出水银之靴减免W（枯萎）长达几秒的致命减速。",
        "【穿透】后期他双抗和血量极高，战士早做多米尼克/黑切，法师做虚空之杖。"
      ]
    },
    "安蓓萨": {
      "aliases": ["狼母", "铁血狼母"],
      "tags": ["平A依赖", "回复怪", "物理爆发"],
      "counters": {
        "S": ["贾克斯", "波比", "雷克顿"],
        "A": ["盖伦", "奥恩", "慎"]
      },
      "tips": [
        "【机制】她极度依赖技能后接平A，因此冰霜之心和铁板靴能废掉她一半输出。",
        "【抓时机】她身板较脆，留硬控技能等她交完位移（Q或R）后再锁定击杀。",
        "【配合】推线时容易被抓，呼叫打野针对可以轻松打崩。"
      ]
    },
    "菲奥娜": {
      "aliases": ["剑姬", "无双剑姬"],
      "tags": ["真伤", "回复怪", "平A依赖"],
      "counters": {
        "S": ["墨菲特", "雷克顿", "潘森"],
        "A": ["瑟提", "贾克斯"]
      },
      "tips": [
        "【破绽】破绽刷在正面时，可以稍微后退脱离视野，让破绽重新刷新到背部。",
        "【骗技能】骗出她的 W（心眼刀）后再交核心控制，否则会被反晕。",
        "【防大招】被套大招时，靠墙站可以防止她打出最后一个破绽触发回血阵。"
      ]
    },
    "卡蜜尔": {
      "aliases": ["青钢影", "剪刀腿"],
      "tags": ["真伤", "平A依赖", "物理爆发"],
      "counters": {
        "S": ["贾克斯", "雷克顿", "提莫"],
        "A": ["盖伦", "内瑟斯"]
      },
      "tips": [
        "【护盾】注意她生命条下方的被动护盾冷却，有被动时不要和她换血。",
        "【真伤】她的 Q2 真伤随 AD 加成，出纯护甲收益低，需要靠心之钢或血量装支撑。",
        "【打断】站在墙体附近时要小心，波比、鳄鱼、武器等英雄可以打断她的 E 技能。"
      ]
    },
    "贾克斯": {
      "aliases": ["武器", "武器大师"],
      "tags": ["平A依赖", "攻速怪", "魔法消耗"],
      "counters": {
        "S": ["墨菲特", "盖伦", "古拉加斯"],
        "A": ["卡蜜尔", "艾瑞莉娅"]
      },
      "tips": [
        "【废除机制】首件做冰霜之心天克贾克斯，极大限制他大招被动的敲击频率。",
        "【骗 E】对拼时不要把重要平A或强化技能打在他的 E（反击风暴）上。",
        "【混伤】他大招提供高额双抗，并且带有魔法伤害，只堆纯护甲容易被他敲碎。"
      ]
    },
    "雷克顿": {
      "aliases": ["鳄鱼", "荒漠屠夫"],
      "tags": ["回复怪", "物理爆发", "高生命"],
      "counters": {
        "S": ["俄洛伊", "盖伦", "奥拉夫"],
        "A": ["赛恩", "莫德凯撒"]
      },
      "tips": [
        "【红怒】红怒 W 会秒破护盾（如瑟提的W），带盾英雄对拼时必须格外小心。",
        "【抗压】铁板靴与守望者铠甲能极大缓解他前期的单杀压力。",
        "【越塔】前期留好保命技能，满怒鳄鱼配合打野三级越塔能力极强。"
      ]
    },
    "艾瑞莉娅": {
      "aliases": ["刀妹", "女刀"],
      "tags": ["平A依赖", "回复怪", "物理爆发"],
      "counters": {
        "S": ["瑟提", "贾克斯", "沃利贝尔"],
        "A": ["杰斯", "提莫"]
      },
      "tips": [
        "【断吸血】必做荆棘背心和冰霜之心，完美克制她高频Q和平A的吸血。",
        "【满层被动】当她利用残血小兵叠满四层被动时绝对不要对拼，伤害差距极大。",
        "【扭比心】走位躲掉她的E（比翼双刃），她就失去了刷Q的资格。"
