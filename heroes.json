  "bpDatabase": {
    "德莱厄斯": {
      "aliases": ["诺手", "断头台"],
      "tags": ["回复怪", "真伤", "物理爆发"],
      "counters": {
        "S": ["杰斯", "提莫", "薇恩"],
        "A": ["赛恩", "蒙多", "内瑟斯"]
      },
      "tips": [
        "【核心】内圈 Q 不会回血且伤害低，如果被无情铁手拉过去，可以直接贴脸打。",
        "【拉扯】不要轻易交出关键位移，保持在他 E 技能范围边缘疯狂拉扯。",
        "【血怒】五层血怒后尽量避战，不要在残血时赌他的大招斩杀线。"
      ]
    },
    "盖伦": {
      "aliases": ["大宝剑", "草丛伦"],
      "tags": ["回复怪", "真伤", "物理爆发"],
      "counters": {
        "S": ["卡蜜尔", "薇恩", "德莱厄斯"],
        "A": ["格温", "纳尔"]
      },
      "tips": [
        "【减伤】守望者铠甲完美压制他的转圈圈伤害，神分/破败打高血量盖伦有奇效。",
        "【被动】利用平A或小技能打断他的脱战回血被动。",
        "【斩杀】注意自身血线，如果头上出现“大反派”标记或半血以下，不要硬拼。"
      ]
    },
    "瑟提": {
      "aliases": ["腕豪", "劲夫"],
      "tags": ["回复怪", "高生命", "真伤", "平A依赖"],
      "counters": {
        "S": ["雷克顿", "沃利贝尔", "杰斯"],
        "A": ["奥拉夫", "凯南", "格温"]
      },
      "tips": [
        "【站位】对拼时利用位移绕到他身后，绝对不要硬吃满蓄力 W 的中心真实伤害。",
        "【拉扯】破舰者+血铠的瑟提单挑极强，没有绝对把握不要站撸，打完一套就撤。",
        "【装备】面对他的巨额护盾，刺客或部分轻装战士可以考虑出【巨蛇之牙】。"
      ]
    },
    "莫德凯撒": {
      "aliases": ["铁男", "金属大师"],
      "tags": ["魔法消耗", "AP坦克", "高生命"],
      "counters": {
        "S": ["奥拉夫", "菲奥娜", "薇恩"],
        "A": ["贾克斯", "卡蜜尔"]
      },
      "tips": [
        "【水银鞋】首件必做水银之靴，不仅提供魔抗，还能减少控制时间。",
        "【拖延】7.2 后金身已从鞋子附魔拆出；仅法师可用探索者的护臂/中娅沙漏拖延大招时间，战士应靠走位、回复与抗性硬撑。",
        "【魔抗】优先做出败魔或自然之力，魔法护盾能完美抵消他的被动和Q。"
      ]
    },
    "亚托克斯": {
      "aliases": ["剑魔", "天神下凡"],
      "tags": ["回复怪", "物理爆发"],
      "counters": {
        "S": ["菲奥娜", "艾瑞莉娅", "克烈"],
        "A": ["赛恩", "盖伦", "蒙多"]
      },
      "tips": [
        "【必出】第一次回家无论如何必须做出死刑宣告或荆棘背心断其吸血。",
        "【规避】向内走位躲避 Q1 和 Q2 的外圈，Q3 时交位移拉开。",
        "【护甲】他的所有伤害均为纯物理伤害，裸出铁板靴性价比极高。"
      ]
    },
    "俄洛伊": {
      "aliases": ["触手妈", "海兽祭司"],
      "tags": ["回复怪", "物理爆发"],
      "counters": {
        "S": ["提莫", "莫德凯撒", "格温"],
        "A": ["薇恩", "杰斯"]
      },
      "tips": [
        "【重伤】面对她极强的阵地回复能力，首件必须掏出重伤散件。",
        "【躲避】走位或留位移躲避她的E（灵魂试炼），一旦被拉必须立刻反打或直接撤出范围。",
        "【大招】当她开启大招（过界信仰）砸地板时，绝对、千万、不要站撸，立刻跑！"
      ]
    },
    "沃利贝尔": {
      "aliases": ["狗熊", "不灭狂雷"],
      "tags": ["回复怪", "魔法消耗", "平A依赖"],
      "counters": {
        "S": ["提莫", "杰斯", "墨菲特"],
        "A": ["薇恩", "凯南"]
      },
      "tips": [
        "【减速】小反甲不仅断其W回血，冰心还能大幅减缓其攻速和被动闪电链触发频率。",
        "【标记】如果头上出现他W的印记，立刻后撤，不要让他咬出带有巨额回血的第二口。",
        "【越塔】小心他大招屏蔽防御塔的机制，残血在塔下并不安全。"
      ]
    },
    "厄加特": {
      "aliases": ["螃蟹", "战车"],
      "tags": ["物理爆发", "高生命"],
      "counters": {
        "S": ["奥拉夫", "慎", "薇恩"],
        "A": ["提莫", "杰斯"]
      },
      "tips": [
        "【克制】小反甲和守望者铠甲完美克制其W技能的高频低伤。",
        "【走位】对拼时贴身并保持在他同一方向，不要让他打出四周所有腿炮的被动爆发。",
        "【前摇】留好位移躲避他前摇明显的E技能（背摔）。"
      ]
    },
    "内瑟斯": {
      "aliases": ["狗头", "沙漠死神"],
      "tags": ["回复怪", "高生命", "物理爆发"],
      "counters": {
        "S": ["德莱厄斯", "奥拉夫", "提莫"],
        "A": ["杰斯", "薇恩"]
      },
      "tips": [
        "【压制】前三级是他最弱的时候，呼叫打野越塔或疯狂控线，绝对不要让他安稳叠Q。",
        "【韧性】出水银之靴减免W（枯萎）长达几秒的致命减速。",
        "【穿透】后期他双抗和血量极高，战士早做多米尼克/黑切，法师做虚空之杖。"
      ]
    },
    "安蓓萨": {
      "aliases": ["狼母", "铁血狼母"],
      "tags": ["平A依赖", "回复怪", "物理爆发"],
      "counters": {
        "S": ["贾克斯", "波比", "雷克顿"],
        "A": ["盖伦", "奥恩", "慎"]
      },
      "tips": [
